{
  "name": "scypp",
  "version": "0.1.0",
  "description": "Modern C++20 port of SciPy, built on NumPP",
  "license": "MIT",
  "dependencies": [
    "numpp"
  ],
  "features": {
    "cuda": { "description": "CUDA backend (via NumPP)" },
    "opencl": { "description": "OpenCL backend (via NumPP)" },
    "metal": { "description": "Metal backend (via NumPP)" },
    "blas": { "description": "BLAS backend (via NumPP)" },
    "lapack": { "description": "LAPACK backend (via NumPP)" }
  }
}
